# Docker project name (used as container prefix)
PROJECT_NAME=octo

# Image tag — used for local builds and docker compose
# For local build: any name (e.g. dev)
# For GHCR pull: latest or specific release (e.g. v1.0.3)
TAG=dev

# Number of tor-backend replicas
REPLICAS=2

# Path to the domain directory containing HS keys
# Structure: domain/<your.onion>/hs_ed25519_secret_key
DIRECTORY=./domain

# Master .onion address — drives Hugo baseURL and config_generator
# Local: http://localhost:80
# Production: http://your.onion
ONION_ADDRESS=http://localhost:80

# Tor log settings (used by config_generator.py)
LOG_LEVEL=notice
LOG_LOCATION=/var/log/tor/onionbalance.log

# Build mode
# true  — build images locally from Dockerfiles
# false — pull images from GHCR using TAG
BUILD=true

# Start monitoring stack (tor-proxy + kuma + socket-proxy)
MONITORING=false
